{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexiBot",
  "version": "0.9.1",
  "identifier": "ai.nexibot.desktop",
  "build": {
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build && cd ../src-tauri && node bundle-bridge.js",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "_bridge_bundle/bridge"
    ],
    "macOS": {
      "frameworks": [
        "../../target/release/deps/libonnxruntime.1.17.1.dylib",
        "../../target/release/deps/libsherpa-onnx-c-api.dylib"
      ],
      "minimumSystemVersion": "12.0",
      "entitlements": "./entitlements.plist",
      "signingIdentity": "A36F0B744DE5018459D54621851C066C40417430"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": [
          "English"
        ]
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "espeak-ng"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyMDU2NzkyMzk1MzgxODQKUldTRWdWTTVrbWNGOG1vZ2hpWUl0WmFadjk3NGhtTWxaOFJvUHIyNUdvVHlLSUJMTEZ5NlFMd3cK",
      "endpoints": []
    },
    "deep-link": {
      "desktop": [
        { "schemes": ["nexibot"] }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NexiBot",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: https://tauri.localhost asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://tauri.localhost; media-src 'self' blob:; connect-src 'self' ipc: https://tauri.localhost http://127.0.0.1:18790 http://127.0.0.1:18791 ws://127.0.0.1:18791 https://api.anthropic.com https://console.anthropic.com"
    }
  }
}